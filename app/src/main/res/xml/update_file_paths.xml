<?xml version="1.0" encoding="utf-8"?>
<!--
  Backs app/src/main/AndroidManifest.xml's FileProvider <provider> entry - scopes the
  content:// Uris AppUpdateInstaller can request to exactly the cache subdirectory
  GitHubUpdateRepository downloads the update APK into (context.cacheDir/updates/). Keep this
  path in sync with GitHubUpdateRepository's UPDATE_CACHE_DIR_NAME constant.
-->
<paths>
    <cache-path
        name="app_updates"
        path="updates/" />
</paths>
