<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- Gates AppUpdateInstaller.canInstallPackages()/installPackage() (the Settings screen's
         "Update to latest" button) - granting this is a special, per-app "install unknown apps"
         toggle the user must flip in system Settings; the permission's mere presence here does
         not enable sideloading by itself, it only lets the app ask the OS whether it's allowed. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- Android 11+ package-visibility: required for MapsLauncher's explicit-package
         resolveActivity() check against the native Google Maps app. Its implicit-browser
         fallback (plain https ACTION_VIEW, no package set) is exempt from this restriction. -->
    <queries>
        <package android:name="com.google.android.apps.maps" />
    </queries>

    <application
        android:name=".InstaMapsApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/full_backup_content"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.InstaMaps">

        <activity
            android:name=".presentation.MainActivity"
            android:exported="true">

            <!-- Launcher entry point -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Instagram/TikTok share target: text/plain because users share the reel's link,
                 not the video file itself. -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>

            <!-- Result-notification tap trampoline, see ShareDeepLink for the contract. -->
            <intent-filter>
                <action android:name="org.neteinstein.instamaps.action.OPEN_MAPS_DESTINATION" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- WorkManager's own manifest declares this service with no foregroundServiceType, so
             the merged manifest defaults to none - ProcessSharedUrlWorker's setForeground() call
             (see ShareNotifier.buildProcessingForegroundInfo, which requests
             FOREGROUND_SERVICE_TYPE_DATA_SYNC) then crashes on Android 14+ with
             "foregroundServiceType ... is not a subset of foregroundServiceType attribute
             0x00000000 in service element of manifest file". Overriding it here with a matching
             type (tools:node="merge" to combine with, not replace, WorkManager's own attributes)
             is the fix documented at
             https://developer.android.com/develop/background-work/background-tasks/persistent/how-to/long-running#foreground-service-types. -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:node="merge" />

        <!-- Lets AppUpdateInstaller hand a downloaded update APK (cached under
             context.cacheDir/updates/ by GitHubUpdateRepository) to the system Package Installer
             as a content:// Uri - a plain file:// Uri would throw FileUriExposedException under
             this app's targetSdk. The authority here must match AppUpdateInstaller's
             FILE_PROVIDER_AUTHORITY_SUFFIX exactly, and update_file_paths.xml's cache-path must
             match GitHubUpdateRepository's download directory exactly. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.update.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/update_file_paths" />
        </provider>

    </application>
</manifest>
